AX_USER=
AX_PASS=
PORT=3000

# Microsoft Entra ID (Azure AD) — SSO
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
REDIRECT_URI=http://localhost:3000/auth/callback
SESSION_SECRET=

# Sentry — error tracking + session replay
# DSN is safe to share (it's the public ingestion endpoint). Leave blank to disable Sentry locally.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Optional — auto-populated on Railway from RAILWAY_GIT_COMMIT_SHA if unset
SENTRY_RELEASE=
